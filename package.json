{
  "name": "sub2api-usage-monitor",
  "displayName": "Sub2api Usage Monitor",
  "description": "Show Sub2api relay API usage and quota information in the VS Code status bar.",
  "version": "0.3.3",
  "publisher": "Esing",
  "author": "Esing",
  "license": "MIT",
  "icon": "assets/logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Zxis233/vscode-sub2api-usage-monitor.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "extensionKind": [
    "ui"
  ],
  "categories": [
    "Other"
  ],
  "keywords": [
    "sub2api",
    "usage",
    "quota",
    "api",
    "statusbar",
    "monitor",
    "relay",
    "token"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    },
    "virtualWorkspaces": true
  },
  "activationEvents": [
    "onStartupFinished",
    "onCommand:sub2apiUsage.refresh",
    "onCommand:sub2apiUsage.setApiKey",
    "onCommand:sub2apiUsage.clearApiKey",
    "onCommand:sub2apiUsage.showDetails",
    "onCommand:sub2apiUsage.openSettings"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "sub2apiUsage.refresh",
        "title": "Sub2api Usage: Refresh"
      },
      {
        "command": "sub2apiUsage.setApiKey",
        "title": "Sub2api Usage: Set API Key"
      },
      {
        "command": "sub2apiUsage.clearApiKey",
        "title": "Sub2api Usage: Clear API Key"
      },
      {
        "command": "sub2apiUsage.showDetails",
        "title": "Sub2api Usage: Show Details"
      },
      {
        "command": "sub2apiUsage.openSettings",
        "title": "Sub2api Usage: Open Settings"
      }
    ],
    "configuration": {
      "title": "Sub2api Usage Monitor",
      "properties": {
        "sub2apiUsage.endpoint": {
          "type": "string",
          "default": "",
          "order": 10,
          "scope": "machine",
          "markdownDescription": "Usage query endpoint. Configure this in user settings. The extension sends tokens only to HTTPS endpoints, except localhost testing."
        },
        "sub2apiUsage.pollIntervalSeconds": {
          "type": "number",
          "default": 300,
          "order": 20,
          "minimum": 30,
          "maximum": 86400,
          "description": "Polling interval in seconds."
        },
        "sub2apiUsage.displayMode": {
          "type": "string",
          "enum": [
            "percentage",
            "quota",
            "remaining",
            "compact"
          ],
          "default": "percentage",
          "order": 30,
          "description": "Status bar display mode."
        },
        "sub2apiUsage.currencySymbol": {
          "type": "string",
          "default": "$",
          "order": 40,
          "description": "Currency prefix for quota values."
        },
        "sub2apiUsage.decimals": {
          "type": "number",
          "default": 2,
          "order": 50,
          "minimum": 0,
          "maximum": 6,
          "description": "Decimal places for money and percentage values."
        },
        "sub2apiUsage.show5h": {
          "type": "boolean",
          "default": true,
          "order": 60,
          "description": "Show the 5h rate limit when available."
        },
        "sub2apiUsage.show7d": {
          "type": "boolean",
          "default": true,
          "order": 70,
          "description": "Show the 7d rate limit when available."
        },
        "sub2apiUsage.placeholderText": {
          "type": "string",
          "default": "Sub2api Usage",
          "order": 80,
          "description": "Status bar text shown when both 5h and 7d rate limit displays are disabled."
        },
        "sub2apiUsage.statusBarAlignment": {
          "type": "string",
          "enum": [
            "left",
            "right"
          ],
          "default": "right",
          "order": 90,
          "description": "Status bar alignment."
        },
        "sub2apiUsage.statusBarPriority": {
          "type": "number",
          "default": 100,
          "order": 100,
          "description": "Status bar priority."
        },
        "sub2apiUsage.threshold.percent.warn": {
          "type": "number",
          "default": 80,
          "order": 110,
          "description": "Use warning icon when 7d usage reaches this percentage."
        },
        "sub2apiUsage.threshold.percent.danger": {
          "type": "number",
          "default": 95,
          "order": 120,
          "description": "Use error icon when 7d usage reaches this percentage."
        },
        "sub2apiUsage.threshold.enableColors": {
          "type": "boolean",
          "default": true,
          "order": 130,
          "description": "Change the status bar background color when 7d usage reaches the warning or danger threshold."
        },
        "sub2apiUsage.threshold.color.warn": {
          "type": "string",
          "enum": [
            "statusBarItem.warningBackground",
            "statusBarItem.errorBackground"
          ],
          "default": "statusBarItem.warningBackground",
          "order": 140,
          "markdownDescription": "VS Code theme color used for the status bar background when 7d usage reaches `sub2apiUsage.threshold.percent.warn`. VS Code currently supports `statusBarItem.warningBackground` and `statusBarItem.errorBackground` for status bar item backgrounds."
        },
        "sub2apiUsage.threshold.color.danger": {
          "type": "string",
          "enum": [
            "statusBarItem.warningBackground",
            "statusBarItem.errorBackground"
          ],
          "default": "statusBarItem.errorBackground",
          "order": 150,
          "markdownDescription": "VS Code theme color used for the status bar background when 7d usage reaches `sub2apiUsage.threshold.percent.danger`. VS Code currently supports `statusBarItem.warningBackground` and `statusBarItem.errorBackground` for status bar item backgrounds."
        },
        "sub2apiUsage.autoStart": {
          "type": "boolean",
          "default": true,
          "order": 160,
          "description": "Start polling automatically after VS Code starts."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run verify",
    "compile": "tsc -p ./tsconfig.build.json",
    "watch": "tsc -watch -p ./",
    "verify": "npm run compile && npm run lint && npm test",
    "lint": "eslint .",
    "test": "vitest run",
    "package": "vsce package"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@types/node": "^20.17.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.6.0",
    "eslint": "^9.29.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.1",
    "vitest": "^4.1.8"
  }
}